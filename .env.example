# Copy to `.env` and fill in the keys for the providers you want to test.
# Only the keys for ENABLED models in config/models.yaml are required; a model
# whose key is missing is skipped with a warning.
#
# NEVER commit the filled-in .env (it is git-ignored).

# 1. Anthropic (Claude)
ANTHROPIC_API_KEY=

# 2. Google (Gemini)
GOOGLE_API_KEY=

# 3. OpenAI (GPT)
OPENAI_API_KEY=

# 4. Mistral
MISTRAL_API_KEY=

# 5. xAI (Grok)
XAI_API_KEY=

# 6. DeepSeek
DEEPSEEK_API_KEY=

# 7. Moonshot AI (Kimi)
MOONSHOT_API_KEY=

# 8. Alibaba (Qwen / DashScope). Either name works; DASHSCOPE_API_KEY wins.
QWEN_API_KEY=
DASHSCOPE_API_KEY=

# 9. Meta Llama via Together AI (Meta has no first-party API)
TOGETHER_API_KEY=

# 10. Cohere (Command R+)
COHERE_API_KEY=
